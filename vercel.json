{
  "framework": "nextjs",
  "redirects": [
    {
      "source": "/Clearpath%20Website",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/Clearpath%20Website.html",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/case-study",
      "destination": "/case-studies/just-windows-usa",
      "permanent": true
    },
    {
      "source": "/case-studies/just-windows",
      "destination": "/case-studies/just-windows-usa",
      "permanent": true
    },
    {
      "source": "/services/website-seo",
      "destination": "/services/seo",
      "permanent": true
    },
    {
      "source": "/services/seo-optimization",
      "destination": "/services/seo",
      "permanent": true
    },
    {
      "source": "/services/microsoft-cloud",
      "destination": "/cloud-advisory",
      "permanent": true
    },
    {
      "source": "/services/microsoft-365",
      "destination": "/cloud-advisory",
      "permanent": true
    },
    {
      "source": "/services/managed-security",
      "destination": "/cloud-advisory",
      "permanent": true
    },
    {
      "source": "/services/cloud-migration",
      "destination": "/cloud-advisory",
      "permanent": true
    },
    {
      "source": "/services/workflow-automation-ai",
      "destination": "/services/ai-automations",
      "permanent": true
    },
    {
      "source": "/services/automation",
      "destination": "/services/ai-automations",
      "permanent": true
    },
    {
      "source": "/services/website-design-hosting",
      "destination": "/services/web-design",
      "permanent": true
    },
    {
      "source": "/services/analytics-advertising",
      "destination": "/packages",
      "permanent": true
    },
    {
      "source": "/stack",
      "destination": "/about",
      "permanent": true
    },
    {
      "source": "/sitemap",
      "destination": "/sitemap.xml",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(robots.txt|sitemap.xml|site.webmanifest)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    }
  ]
}
